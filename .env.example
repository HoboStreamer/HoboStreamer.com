# HoboStreamer Configuration
# Copy this to .env and fill in your values

# Platform Admin — username of the site owner (applied on first setup only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
BASE_URL=http://localhost:3000

# JWT Secret (generate a strong random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Database
DB_PATH=./data/hobostreamer.db

# RTMP Server
RTMP_PORT=1935
RTMP_CHUNK_SIZE=60000

# JSMPEG Relay
JSMPEG_VIDEO_PORT=9710
JSMPEG_AUDIO_PORT=9711

# WebRTC / Mediasoup
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=10100
WEBRTC_PORT=4443

# TURN Server (coturn) — required for NAT traversal
TURN_URL=turn:your-server-ip:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# PayPal (for Hobo Bucks cashout)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# VOD Storage
VOD_PATH=./data/vods
COLD_STORAGE_PATH=/mnt/hobo-cold/vods
CLIPS_PATH=./data/clips
MAX_VOD_SIZE_MB=2048

# Hobo Bucks
MIN_CASHOUT=5
ESCROW_HOLD_DAYS=14

# Word Filter
UNSAFE_WORDS_PATH=./server/chat/unsafe-words.txt
